# Variáveis locais de desenvolvimento — copie para .dev.vars (ignorado pelo git).
# Em produção, use `wrangler secret put <NAME>` para cada secret.

# Marca o ambiente. Em prod, este valor vem como env var no Worker.
ENVIRONMENT=development

# CSV de origins aceitas em CORS/CSRF. Em dev, normalmente só o Vite local.
# Em prod vai por `vars.ALLOWED_ORIGINS` em wrangler.jsonc.
ALLOWED_ORIGINS=http://localhost:5173

# Sentry DSN. Em dev local fica vazio (Sentry no-op). Em prod, configurar via
# `pnpm dlx wrangler secret put SENTRY_DSN`.
SENTRY_DSN=

# Adicione secrets locais aqui à medida que stories futuras (auth, Resend) os introduzirem.
# Exemplos (não usar valores reais):
# RESEND_API_KEY=
# SESSION_SECRET=
