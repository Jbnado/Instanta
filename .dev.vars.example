# Variáveis locais de desenvolvimento — copie para .dev.vars (ignorado pelo git).
# Em produção, use `wrangler secret put <NAME>` para cada secret.

# Marca o ambiente. Em prod, este valor vem como env var no Worker.
ENVIRONMENT=development

# CSV de origins aceitas em CORS/CSRF. Em dev, normalmente só o Vite local.
# Em prod vai por `vars.ALLOWED_ORIGINS` em wrangler.jsonc.
ALLOWED_ORIGINS=http://localhost:5173

# Sentry DSN. Em dev local fica vazio (Sentry no-op). Em prod, configurar via
# `pnpm dlx wrangler secret put SENTRY_DSN`.
SENTRY_DSN=

# Adicione secrets locais aqui à medida que stories futuras (auth, Resend) os introduzirem.
# Exemplos (não usar valores reais):
# RESEND_API_KEY=

# JWT HS256 pro access token de auth (Story 2.1).
# Em dev local: gere com `node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"`.
# Em prod: `wrangler secret put AUTH_JWT_SECRET`. NUNCA commitar valor real aqui.
AUTH_JWT_SECRET=dev-only-rotate-me-with-real-secret-generated-locally

# Chave AES-GCM (32 bytes em base64) que cifra o secret TOTP do MFA admin (Story 2.7/2.8).
# SEPARADA do AUTH_JWT_SECRET (NFR45).
# Gere com: `openssl rand -base64 32`.
# Em prod: `wrangler secret put MFA_ENCRYPTION_KEY`. NUNCA commitar valor real aqui.
MFA_ENCRYPTION_KEY=dev-only-mfa-key-base64-32-bytes-replace-me=

# Storage de fotos: Cloudflare R2 (Epic 6 — pivot do stub CF Images → R2 free tier).
# NÃO há secret pra isso: o R2 é um BINDING (`PHOTOS`) declarado em wrangler.jsonc, não
# uma var/secret. Em dev local, `wrangler dev`/miniflare criam um bucket R2 efêmero
# automaticamente pro binding. Em prod, o bucket `instanta-photos` precisa existir:
#   wrangler r2 bucket create instanta-photos   (R2 habilitado na conta CF)
# Ver docs/runbook.md § R2.
