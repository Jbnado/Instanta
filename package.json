{
	"name": "instanta",
	"description": "Instanta — feed colaborativo de fotos por evento (Vite + React + Hono + Cloudflare Workers)",
	"dependencies": {
		"@fontsource-variable/geist": "^5.2.8",
		"@hono/zod-validator": "^0.8.0",
		"@hookform/resolvers": "^5.4.0",
		"@sentry/cloudflare": "^10.53.1",
		"@tanstack/react-router": "^1.170.7",
		"@tanstack/router-devtools": "^1.167.0",
		"@zxcvbn-ts/core": "^3.0.4",
		"@zxcvbn-ts/language-common": "^3.0.4",
		"@zxcvbn-ts/language-pt-br": "^3.0.2",
		"argon2-wasm-edge": "^1.0.23",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"hono": "4.11.1",
		"lucide-react": "^1.14.0",
		"radix-ui": "^1.4.3",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"react-hook-form": "^7.76.0",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"uuidv7": "^1.2.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@cloudflare/vite-plugin": "1.15.3",
		"@cloudflare/vitest-pool-workers": "^0.16.6",
		"@eslint/js": "9.39.1",
		"@faker-js/faker": "^10.4.0",
		"@fast-check/vitest": "^0.4.1",
		"@playwright/test": "^1.60.0",
		"@tailwindcss/vite": "^4.2.4",
		"@tanstack/router-plugin": "^1.168.10",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "24.10.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "5.1.1",
		"@vitest/coverage-v8": "^4.1.6",
		"drizzle-kit": "^0.31.10",
		"eslint": "9.39.2",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.4.24",
		"globals": "16.5.0",
		"jsdom": "^29.1.1",
		"shadcn": "^4.7.0",
		"tailwindcss": "^4.2.4",
		"typescript": "5.8.3",
		"typescript-eslint": "8.48.0",
		"vite": "^6.0.0",
		"vitest": "^4.1.6",
		"wrangler": "4.90.0"
	},
	"private": true,
	"scripts": {
		"build": "tsc -b && vite build",
		"cf-typegen": "wrangler types",
		"check": "tsc && vite build && wrangler deploy --dry-run",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply instanta-dev --local",
		"db:migrate:remote": "wrangler d1 migrations apply instanta-dev --remote",
		"deploy": "wrangler deploy",
		"dev": "vite",
		"lint": "eslint .",
		"preview": "pnpm run build && vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:client": "vitest run --project=client",
		"test:workers": "vitest run --project=workers",
		"test:coverage": "vitest run --coverage --project=client",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"check:bundle-size": "node scripts/check-bundle-size.mjs",
		"fr:check": "node scripts/fr-check.mjs",
		"verify:domain": "node scripts/verify-domain.mjs",
		"typecheck": "tsc -b --noEmit && tsc -p tsconfig.tests.json --noEmit"
	},
	"type": "module"
}
